# Environment Configuration for VulnSentinel
# Copy to .env and fill in your values

# App
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Storage
STORE_BACKEND=sqlite  # or "memory"
DB_PATH=vulnsentinel.db
MAX_MEMORY_TASKS=500
DATABASE_URL=

# Scanner
SEMGREP_CONFIG=auto
SCAN_TIMEOUT_SECONDS=300
CLONE_DEPTH=1

# LLM
LLM_PROVIDER=openai  # or "gemini"
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
LLM_MODEL=gpt-4-turbo
LLM_CONCURRENCY=3
LLM_MAX_FILE_CHARS=200000
LLM_MAX_RETRIES=2

# GitHub
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_WEBHOOK_MAX_CONCURRENCY=3
GITHUB_WEBHOOK_POST_PR_COMMENT=true

# Auth & Security
AUTH_ENABLED=false
AUTH_DB_BACKEND=sqlite
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Queue
QUEUE_BACKEND=local  # or "redis"
REDIS_URL=

# Billing (Stripe)
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# License Verification
LICENSE_BOOTSTRAP_KEY=
LICENSE_BOOTSTRAP_OWNER=
LICENSE_TRACK_NEW_IPS=true

# Pilot Automation
AUTO_PILOT_ENABLED=false
AUTO_PILOT_MIN_TEAM_SIZE=0
AUTO_PILOT_ALLOWED_DOMAINS=

# Pilot Email
PILOT_EMAIL_ENABLED=false
PILOT_EMAIL_FROM=
PILOT_REMINDER_SUBJECT=
PILOT_REMINDER_DAYS=3,7,14
PILOT_REMINDER_INTERVAL_HOURS=24

# Alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENTS=alerts@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourdomain.com
SMTP_USE_TLS=true
SLACK_WEBHOOK_URL=

# Auto-remediation
REMEDIATE_SEVERITIES=ERROR,WARNING,HIGH,MEDIUM
